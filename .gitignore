# Binario Node.js bundled (91 MB, solo v1). L'utente lo scarica separatamente (vedi README).
node.exe
*.exe

# Binari Go (planck su Linux/macOS — niente estensione)
/planck
/planck-darwin
/planck-linux

# Artefatti test Go
*.test
*.out
coverage.txt

# Stato runtime (rigenerato ad ogni avvio)
_traffico_log.txt
_blocked_domains.txt
config.json
studenti.json

# DB SQLite v2 (config, sessioni, classi, mappa studenti) — dati personali.
planck.db
planck.db-shm
planck.db-wal

# Cache lista AI scaricata da GitHub al boot (rigenerata).
ai-domains-cache.txt

# Log file (rigenerato ad ogni boot, file di sessione corrente).
planck.log

# Profile dir Edge/Chrome usata per la finestra app-mode (cookies,
# cache, ecc., dedicata e isolata da quella personale dell'utente).
.planck-browser-profile/

# Script studenti auto-generati a ogni boot da Planck v2 (IP della
# rete locale → ogni macchina ha valori diversi). I template sono
# in internal/scripts/scripts.go.
/proxy_on.bat
/proxy_off.bat
/proxy_on.vbs
/proxy_off.vbs

# Sessioni archiviate (contengono IP + domini visitati dagli studenti = dati sensibili)
sessioni/*.json
sessioni/*.ndjson
sessioni/_archivio_privato/

# Mappe classi salvate (contengono nomi studenti reali)
classi/*.json

# File temporanei di smoke test / debug
_server.log
_smoke.json
_*.log

# Sistema operativo
Thumbs.db
.DS_Store
desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Directory editor / stato locale della sessione di lavoro
.claude/

# Versione precedente tenuta in locale per confronto
old/

# Veyon test rig: chiavi RSA generate ad ogni `docker run`, mai committare.
test/veyon-rig/keys/
*.pem
